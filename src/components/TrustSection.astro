---
---

<section class="mx-auto max-w-6xl px-6 py-16">
  <h2 class="mb-8 text-center font-mono text-2xl font-bold text-foreground">
    Trust & Transparency
  </h2>
  <div class="grid gap-4 md:grid-cols-2">
    <!-- Security -->
    <div class="rounded-lg border-2 border-primary/30 bg-card p-8">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="text-primary"
        aria-hidden="true"
      >
        <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z" />
      </svg>
      <h3 class="mt-4 font-mono text-lg font-bold text-foreground">
        Zero Telemetry.
      </h3>
      <p class="font-mono text-lg font-bold text-foreground">
        Local Environment Variables.
      </p>
      <p class="font-mono text-lg font-bold text-primary">
        100% Open Source.
      </p>
      <p class="mt-4 text-sm text-muted-foreground">
        No analytics. No phone-home. Your API keys stay in your environment. Audit every line of code.
      </p>
    </div>

    <!-- Cost -->
    <div class="rounded-lg border border-accent/30 bg-card p-8">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="text-accent"
        aria-hidden="true"
      >
        <path d="m15.5 7.5 2.3 2.3a1 1 0 0 0 1.4 0l2.1-2.1a1 1 0 0 0 0-1.4L19 4" />
        <path d="m21 2-9.6 9.6" />
        <circle cx="7.5" cy="15.5" r="5.5" />
      </svg>
      <h3 class="mt-4 font-mono text-lg font-bold text-foreground">
        Bring Your Own Key
      </h3>
      <p class="mt-2 font-mono text-2xl font-bold text-accent">$0</p>
      <p class="mt-1 text-sm text-muted-foreground">
        recurring software costs.
      </p>
      <p class="mt-4 text-sm text-muted-foreground">
        Use your own Groq API key. Pay only for what you use. No subscriptions, no tiers, no vendor lock-in.
      </p>
    </div>
  </div>
</section>
