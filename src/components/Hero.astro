---
const installCmd = 'curl -fsSL https://yap.sh/install | bash';
---

<section class="relative flex flex-col items-center px-6 pt-32 pb-20">
  <p class="speakable-definition sr-only">yap is a free, open-source voice-to-text CLI that converts speech to text at your cursor. It runs on Linux, macOS, and Windows with ~5 MB RAM.</p>
  <h1 class="max-w-3xl text-center text-4xl font-bold leading-tight tracking-tight text-foreground sm:text-5xl lg:text-6xl">
    Lightweight voice-to-text for your desktop.
  </h1>
  <p class="mt-5 max-w-xl text-center text-lg text-muted-foreground">
    Hold a key. Speak. Text appears at your cursor. Zero idle footprint.
  </p>
  <p class="mt-4 max-w-2xl text-center text-sm leading-relaxed text-muted-foreground/80">
    yap is a free, open-source voice-to-text CLI built with Go. It runs as a single
    static binary on Linux, macOS, and Windows with no runtime dependencies. Audio is
    transcribed via the Groq Whisper API in ~1–2 seconds, and yap uses just ~5–10 MB of
    RAM when idle — a fraction of typical desktop dictation software.
  </p>

  <!-- Terminal demo window -->
  <div class="mt-12 w-full max-w-2xl overflow-hidden rounded-lg border border-border bg-card">
    <div class="flex items-center gap-2 border-b border-border px-4 py-2.5">
      <div class="h-3 w-3 rounded-full bg-destructive/60"></div>
      <div class="h-3 w-3 rounded-full bg-primary/40"></div>
      <div class="h-3 w-3 rounded-full bg-accent/40"></div>
      <span class="ml-2 font-mono text-xs text-muted-foreground">terminal</span>
    </div>
    <div class="flex min-h-[200px] items-center justify-center p-8">
      <div class="text-center">
        <div class="font-mono text-sm text-foreground/70">
          <span class="text-primary">$</span> yap listen
        </div>
        <div class="mt-3 font-mono text-xs text-foreground/50">
          <span class="text-primary/60">&#9654;</span> listening for hotkey...
          <span class="animate-blink text-accent">&#9608;</span>
        </div>
        <p class="mt-6 text-xs text-foreground/40">Demo GIF placeholder — hold-to-talk workflow</p>
      </div>
    </div>
  </div>

  <!-- Install command + GitHub CTA -->
  <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row">
    <button
      id="copy-btn"
      data-cmd={installCmd}
      class="group flex items-center gap-3 rounded-md border border-primary bg-primary/5 px-5 py-3 font-mono text-sm text-foreground transition-colors hover:bg-primary/10 cursor-pointer"
    >
      <span class="text-primary">$</span>
      <span class="text-muted-foreground">{installCmd}</span>
      <!-- Copy icon (shown by default) -->
      <svg
        id="icon-copy"
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="text-muted-foreground transition-colors group-hover:text-accent"
        aria-hidden="true"
      >
        <rect width="14" height="14" x="8" y="8" rx="2" ry="2" />
        <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2" />
      </svg>
      <!-- Check icon (hidden by default, shown after copy) -->
      <svg
        id="icon-check"
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="hidden text-primary"
        aria-hidden="true"
      >
        <path d="M20 6 9 17l-5-5" />
      </svg>
    </button>

    <a
      href="https://github.com/enriquefft/yap"
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-2 rounded-md border border-border bg-secondary px-5 py-3 font-mono text-sm text-foreground transition-colors hover:border-accent/50 hover:text-accent"
    >
      View on GitHub
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M15 3h6v6" />
        <path d="M10 14 21 3" />
        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
      </svg>
    </a>
  </div>
</section>

<script>
  const btn = document.getElementById('copy-btn') as HTMLButtonElement;
  const iconCopy = document.getElementById('icon-copy') as SVGElement;
  const iconCheck = document.getElementById('icon-check') as SVGElement;

  if (btn && iconCopy && iconCheck) {
    btn.addEventListener('click', async () => {
      const cmd = btn.dataset.cmd ?? '';
      try {
        await navigator.clipboard.writeText(cmd);
        iconCopy.classList.add('hidden');
        iconCheck.classList.remove('hidden');
        setTimeout(() => {
          iconCopy.classList.remove('hidden');
          iconCheck.classList.add('hidden');
        }, 2000);
      } catch {
        // Clipboard API unavailable — command is still visible on screen
      }
    });
  }
</script>
