---
import { faqs } from '../data/faqs';
---

<section class="mx-auto max-w-4xl px-6 py-16">
  <h2 class="mb-8 text-center font-mono text-2xl font-bold text-foreground">
    Frequently Asked Questions
  </h2>
  <div class="space-y-3">
    {faqs.map((faq) => (
      <details class="group rounded-lg border border-border bg-card">
        <summary class="cursor-pointer select-none px-6 py-4 font-mono text-sm font-semibold text-foreground transition-colors hover:text-primary">
          {faq.q}
        </summary>
        <div class="border-t border-border px-6 py-4 text-sm leading-relaxed text-muted-foreground">
          {faq.a}
        </div>
      </details>
    ))}
  </div>
</section>
