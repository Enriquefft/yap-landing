---
const columns = [
  {
    heading: 'Source',
    items: [
      { label: 'GitHub Repository', href: 'https://github.com/enriquefft/yap' },
      { label: 'Issue Tracker', href: 'https://github.com/enriquefft/yap/issues' },
    ],
  },
  {
    heading: 'Docs',
    items: [
      { label: 'Installation Guide', href: 'https://github.com/enriquefft/yap#installation' },
      { label: 'Configuration', href: 'https://github.com/enriquefft/yap#configuration' },
    ],
  },
  {
    heading: 'Share',
    items: [
      { label: 'github.com/enriquefft/yap', href: 'https://github.com/enriquefft/yap' },
      { label: 'yap.enriquefft.com', href: 'https://yap.enriquefft.com' },
    ],
  },
];
---

<footer class="border-t border-zinc-800">
  <div class="mx-auto grid max-w-6xl grid-cols-1 gap-8 px-6 py-12 sm:grid-cols-3">
    {columns.map((col) => (
      <div>
        <h4 class="font-mono text-xs font-semibold uppercase tracking-widest text-muted-foreground">
          {col.heading}
        </h4>
        <ul class="mt-3 space-y-2">
          {col.items.map((item) => (
            <li>
              <a
                href={item.href}
                target="_blank"
                rel="noopener noreferrer"
                class="font-mono text-sm text-foreground/70 transition-colors hover:text-accent"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
  <div class="border-t border-border px-6 py-4 text-center font-mono text-xs text-muted-foreground/50">
    Built with Go
  </div>
</footer>
