---
---

<section class="mx-auto max-w-6xl px-6 py-20">
  <h2 class="mb-8 text-center font-mono text-2xl font-bold text-foreground">
    Features
  </h2>

  <!-- Hold-to-Talk Workflow — full-width banner -->
  <div
    class="bento-card mb-4 w-full rounded-lg border border-border bg-card p-6 opacity-0 translate-y-6"
    data-delay="0"
  >
    <div class="flex items-start gap-3">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="mt-0.5 shrink-0 text-primary"
        aria-hidden="true"
      >
        <path d="M12 19v3" />
        <path d="M19 10v2a7 7 0 0 1-14 0v-2" />
        <rect x="9" y="2" width="6" height="13" rx="3" />
      </svg>
      <div class="w-full">
        <h3 class="font-mono text-sm font-semibold text-foreground">Hold-to-Talk Workflow</h3>
        <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-4">
          {[
            { step: '1', label: 'Hold', desc: 'Press hotkey' },
            { step: '2', label: 'Speak', desc: 'Record audio' },
            { step: '3', label: 'Release', desc: 'Send to API' },
            { step: '4', label: 'Text', desc: 'Appears at cursor' },
          ].map((s) => (
            <div class="rounded-md border border-border bg-secondary/50 p-3 text-center">
              <span class="font-mono text-lg font-bold text-primary">{s.step}</span>
              <p class="mt-1 font-mono text-xs font-semibold text-foreground">{s.label}</p>
              <p class="text-[10px] text-muted-foreground">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- 2x2 features grid -->
  <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
    <!-- Memory -->
    <div
      class="bento-card rounded-lg border border-border bg-card p-6 opacity-0 translate-y-6"
      data-delay="100"
    >
      <div class="flex items-start gap-3">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="mt-0.5 shrink-0 text-primary"
          aria-hidden="true"
        >
          <rect x="4" y="4" width="16" height="16" rx="2" />
          <rect x="9" y="9" width="6" height="6" rx="1" />
          <path d="M15 2v2" /><path d="M15 20v2" />
          <path d="M2 15h2" /><path d="M2 9h2" />
          <path d="M20 15h2" /><path d="M20 9h2" />
          <path d="M9 2v2" /><path d="M9 20v2" />
        </svg>
        <div>
          <h3 class="font-mono text-sm font-semibold text-foreground">Memory</h3>
          <p class="mt-1 font-mono text-2xl font-bold text-primary">~5-10MB</p>
          <p class="mt-0.5 text-xs text-muted-foreground">yap uses just ~5–10 MB RAM when idle with negligible CPU when not recording.</p>
          <div class="mt-4 h-2 w-full overflow-hidden rounded-full bg-secondary">
            <div class="h-full w-[3%] rounded-full bg-primary"></div>
          </div>
          <div class="mt-1 flex justify-between font-mono text-[10px] text-muted-foreground">
            <span>yap</span>
            <span class="text-muted-foreground/40">typical desktop app ~200MB+</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Speed -->
    <div
      class="bento-card rounded-lg border border-border bg-card p-6 opacity-0 translate-y-6"
      data-delay="200"
    >
      <div class="flex items-start gap-3">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="mt-0.5 shrink-0 text-accent"
          aria-hidden="true"
        >
          <path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z" />
        </svg>
        <div>
          <h3 class="font-mono text-sm font-semibold text-foreground">Speed</h3>
          <p class="mt-1 font-mono text-2xl font-bold text-accent">~1-2s</p>
          <p class="mt-0.5 text-xs text-muted-foreground">yap transcribes in ~1–2s after you release the hotkey.</p>
          <p class="mt-2 font-mono text-xs text-muted-foreground/70">
            Powered by <span class="text-accent">Groq Whisper API</span>
          </p>
        </div>
      </div>
    </div>

    <!-- Portability -->
    <div
      class="bento-card rounded-lg border border-border bg-card p-6 opacity-0 translate-y-6"
      data-delay="300"
    >
      <div class="flex items-start gap-3">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="mt-0.5 shrink-0 text-accent"
          aria-hidden="true"
        >
          <path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z" />
          <path d="m3.3 7 8.7 5 8.7-5" />
          <path d="M12 22V12" />
        </svg>
        <div>
          <h3 class="font-mono text-sm font-semibold text-foreground">Portability</h3>
          <p class="mt-1 text-sm text-muted-foreground">yap ships as a single static Go binary with no runtime dependencies.</p>
          <div class="mt-3 flex gap-4 font-mono text-xs text-muted-foreground">
            <span class="rounded border border-border px-2 py-1">Linux</span>
            <span class="rounded border border-border px-2 py-1">macOS</span>
            <span class="rounded border border-border px-2 py-1">Windows</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Configuration -->
    <div
      class="bento-card rounded-lg border border-border bg-card p-6 opacity-0 translate-y-6"
      data-delay="400"
    >
      <div class="flex items-start gap-3">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="mt-0.5 shrink-0 text-primary"
          aria-hidden="true"
        >
          <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z" />
          <circle cx="12" cy="12" r="3" />
        </svg>
        <div>
          <h3 class="font-mono text-sm font-semibold text-foreground">Configuration</h3>
          <p class="mt-1 text-sm text-muted-foreground">yap includes a first-class NixOS module and uses standard TOML config.</p>
          <pre class="mt-3 overflow-x-auto rounded border border-border bg-secondary/50 p-3 font-mono text-[11px] text-foreground/70">[transcription]
provider = "groq"

[hotkey]
key = "Super_R"</pre>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const cards = document.querySelectorAll<HTMLElement>('.bento-card');

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        const delay = el.dataset.delay ?? '0';
        el.style.transition = `opacity 0.5s ease ${delay}ms, transform 0.5s ease ${delay}ms`;
        el.classList.remove('opacity-0', 'translate-y-6');
        observer.unobserve(el);
      });
    },
    { threshold: 0.15 }
  );

  cards.forEach((card) => observer.observe(card));
</script>
